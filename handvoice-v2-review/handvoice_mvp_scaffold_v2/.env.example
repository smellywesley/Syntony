# scripts/start_demo.ps1 generates a unique value when it creates .env.
# Never deploy one of the known placeholder strings rejected by the API.
HANDVOICE_BOOTSTRAP_KEY=replace-with-a-long-random-value
HANDVOICE_MAXIMUM_MEDIA_BYTES=67108864
POSTGRES_DB=handvoice
POSTGRES_USER=handvoice
POSTGRES_PASSWORD=replace-this-local-password
