{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handvoice.local/schemas/motor-training-manifest.v1.json",
  "title": "HandVoice Motor Event Training Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_version",
    "dataset",
    "claim_boundary",
    "annotators_blinded_to_detector",
    "consensus_adjudicated_without_detector",
    "cases"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "profile_version": {"const": "handvoice-motor-training-v1"},
    "claim_boundary": {"const": "motor_event_measurement_only"},
    "annotators_blinded_to_detector": {"const": true},
    "consensus_adjudicated_without_detector": {"const": true},
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "doi", "license", "kind", "human_annotated"],
      "properties": {
        "id": {"$ref": "#/$defs/safeId"},
        "doi": {"type": "string", "minLength": 3, "maxLength": 120},
        "license": {"type": "string", "minLength": 3, "maxLength": 80},
        "kind": {"enum": ["human_recordings", "synthetic_development"]},
        "human_annotated": {"type": "boolean"}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 3,
      "maxItems": 1000,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "eventTimes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 300,
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0, "maximum": 10000}
    },
    "raterEvents": {
      "type": "object",
      "minProperties": 2,
      "maxProperties": 5,
      "propertyNames": {"pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"},
      "additionalProperties": {"$ref": "#/$defs/eventTimes"}
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "participant_id",
        "split",
        "task_code",
        "hand",
        "landmark_file",
        "landmark_sha256",
        "source_video_sha256",
        "strata",
        "rater_events_ms",
        "consensus_events_ms"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/safeId"},
        "participant_id": {"$ref": "#/$defs/safeId"},
        "split": {"enum": ["train", "validation", "test"]},
        "task_code": {"const": "T01"},
        "hand": {"const": "right"},
        "landmark_file": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240,
          "pattern": "^[A-Za-z0-9_./-]+\\.json$"
        },
        "landmark_sha256": {"$ref": "#/$defs/sha256"},
        "source_video_sha256": {"$ref": "#/$defs/sha256"},
        "strata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["device", "condition", "performance_band"],
          "properties": {
            "device": {"$ref": "#/$defs/safeId"},
            "condition": {"$ref": "#/$defs/safeId"},
            "performance_band": {"$ref": "#/$defs/safeId"}
          }
        },
        "rater_events_ms": {"$ref": "#/$defs/raterEvents"},
        "consensus_events_ms": {"$ref": "#/$defs/eventTimes"}
      }
    }
  }
}
