{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handvoice.local/schemas/motor-study-plan.v1.json",
  "title": "HandVoice Motor Study Assembly Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_version",
    "dataset",
    "claim_boundary",
    "annotators_blinded_to_detector",
    "consensus_adjudicated_without_detector",
    "cases"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "profile_version": {"const": "handvoice-motor-study-plan-v1"},
    "claim_boundary": {"const": "motor_event_measurement_only"},
    "annotators_blinded_to_detector": {"const": true},
    "consensus_adjudicated_without_detector": {"const": true},
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "doi", "license", "kind", "human_annotated"],
      "properties": {
        "id": {"$ref": "#/$defs/safeId"},
        "doi": {"type": "string", "minLength": 3, "maxLength": 120},
        "license": {"type": "string", "minLength": 3, "maxLength": 80},
        "kind": {"enum": ["human_recordings", "synthetic_development"]},
        "human_annotated": {"type": "boolean"}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 3,
      "maxItems": 1000,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "eventTimes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 300,
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0, "maximum": 10000}
    },
    "jsonPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9_./-]+\\.json$"
    },
    "annotationPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9_./-]+\\.events\\.json$"
    },
    "videoPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9_./-]+\\.(mp4|webm|mov)$"
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "participant_id",
        "split",
        "task_code",
        "hand",
        "source_video_file",
        "landmark_file",
        "rater_annotation_files",
        "consensus_events_ms",
        "strata"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/safeId"},
        "participant_id": {"$ref": "#/$defs/safeId"},
        "split": {"enum": ["train", "validation", "test"]},
        "task_code": {"const": "T01"},
        "hand": {"const": "right"},
        "source_video_file": {"$ref": "#/$defs/videoPath"},
        "landmark_file": {"$ref": "#/$defs/jsonPath"},
        "rater_annotation_files": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/annotationPath"}
        },
        "consensus_events_ms": {"$ref": "#/$defs/eventTimes"},
        "strata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["device", "condition", "performance_band"],
          "properties": {
            "device": {"$ref": "#/$defs/safeId"},
            "condition": {"$ref": "#/$defs/safeId"},
            "performance_band": {"$ref": "#/$defs/safeId"}
          }
        }
      }
    }
  }
}
