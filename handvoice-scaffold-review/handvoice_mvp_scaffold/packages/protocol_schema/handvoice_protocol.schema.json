{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handvoice.local/schemas/protocol.v1.json",
  "title": "HandVoice Protocol",
  "type": "object",
  "required": [
    "schema_version",
    "protocol_version",
    "timing",
    "repetitions",
    "task_definitions",
    "sequences"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string"
    },
    "positioning": {
      "const": "functional_measurement_not_diagnosis"
    },
    "timing": {
      "type": "object",
      "required": [
        "pre_roll_ms",
        "active_ms",
        "post_roll_ms"
      ],
      "properties": {
        "pre_roll_ms": {
          "type": "integer",
          "minimum": 0
        },
        "active_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "post_roll_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "repetitions": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "equal_priority_instruction_required": {
      "type": "boolean"
    },
    "task_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "code",
          "name",
          "condition"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^T[0-9]{2}$"
          },
          "name": {
            "type": "string"
          },
          "condition": {
            "enum": [
              "single",
              "dual"
            ]
          },
          "hand": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "left",
              "right",
              null
            ]
          },
          "speech_task": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "sequences": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "quality_defaults": {
      "type": "object"
    },
    "coupling": {
      "type": "object"
    }
  },
  "additionalProperties": false
}